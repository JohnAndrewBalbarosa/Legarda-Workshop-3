# Translation provider — Google Gemini 1.5 Flash (free tier: 15 req/min, 1500/day)
# Get a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Seat-style translation pool. Comma-separated tokens — one per active
# participant. The COUNT here is the room capacity: if there are 30 seats in
# the room, configure 30 tokens. The presenter assigns one to each user on
# connect. On disconnect a seat is HELD for 10 minutes before it can be
# reassigned to a new participant. Each seat is capped at 3 LLM calls across
# all translation modes (Tagalog / Taglish / Other) — cache hits and queue
# broadcasts are free and do not consume the seat's allowance.
TRANSLATION_KEYS=tok-001,tok-002,tok-003,tok-004,tok-005,tok-006,tok-007,tok-008,tok-009,tok-010,tok-011,tok-012,tok-013,tok-014,tok-015,tok-016,tok-017,tok-018,tok-019,tok-020,tok-021,tok-022,tok-023,tok-024,tok-025,tok-026,tok-027,tok-028,tok-029,tok-030,tok-031,tok-032,tok-033,tok-034,tok-035,tok-036,tok-037,tok-038,tok-039,tok-040,tok-041,tok-042,tok-043,tok-044,tok-045,tok-046,tok-047,tok-048,tok-049,tok-050

# Presenter websocket
PRESENTER_HOST=127.0.0.1
PRESENTER_PORT=5050
PRESENTER_WS=ws://127.0.0.1:5050
